{
  "type": "webhook",
  "name": "caller_identity_lookup",
  "description": "Look up a returning customer by their phone number. Call this at the very start of the conversation to check if the caller is a known customer. If found, greet them by name and reference their vehicle. If not found, proceed with a standard new-customer greeting.",
  "response_timeout_secs": 8,
  "execution_mode": "immediate",
  "disable_interruptions": true,
  "pre_tool_speech": "auto",
  "tool_call_sound": null,
  "tool_call_sound_behavior": "auto",
  "tool_error_handling_mode": "auto",
  "dynamic_variables": { "dynamic_variable_placeholders": {} },
  "assignments": [],
  "api_schema": {
    "url": "https://crm.callsaas.io/api/tools/caller-identity",
    "method": "POST",
    "content_type": "application/json",
    "request_headers": {
      "X-Webhook-Secret": {
        "constant_value": "REPLACE_WITH_TENANT_WEBHOOK_SECRET"
      }
    },
    "path_params_schema": {},
    "query_params_schema": null,
    "request_body_schema": {
      "type": "object",
      "description": "Caller identification request",
      "required": ["caller_phone"],
      "properties": {
        "caller_phone": {
          "type": "string",
          "description": "The caller's phone number as provided by the telephony system",
          "dynamic_variable": "caller_id",
          "constant_value": "",
          "is_system_provided": false
        },
        "tenant_id": {
          "type": "string",
          "description": "The workshop tenant identifier",
          "dynamic_variable": "",
          "constant_value": "REPLACE_WITH_TENANT_ID",
          "is_system_provided": false
        }
      }
    },
    "response_body_schema": null
  }
}
